locals {
  meta   = jsondecode(file("${get_terragrunt_dir()}/hyops.meta.json"))
  inputs = jsondecode(file("${get_terragrunt_dir()}/hyops.inputs.json"))

  # Import AWS-derived locals produced by the same profile.
  aws = read_terragrunt_config("${get_terragrunt_dir()}/aws.locals.hcl").locals

  tfc_org      = get_env("TFC_ORG", "hybridops-tech")
  backend_mode = lower(trimspace(get_env("HYOPS_TERRAFORM_BACKEND_MODE", "cloud")))
  runtime_root = trimspace(get_env("HYOPS_RUNTIME_ROOT", "."))
  terraform_state_path = "${local.runtime_root}/state/terraform/${local.meta.module_id}.tfstate"

  workspace_name = trimspace(try(tostring(local.meta.workspace_name), ""))

  aws_access_key_expr    = local.aws.access_key_id != "" ? "\"${local.aws.access_key_id}\"" : "null"
  aws_secret_key_expr    = local.aws.secret_access_key != "" ? "\"${local.aws.secret_access_key}\"" : "null"
  aws_session_token_expr = local.aws.session_token != "" ? "\"${local.aws.session_token}\"" : "null"
  aws_profile_expr       = local.aws.profile != "" ? "\"${local.aws.profile}\"" : "null"

  # Pass through all merged module inputs to Terraform.
  tf_inputs = local.inputs
}

generate "backend_local" {
  disable   = local.backend_mode != "local"
  path      = "backend.tf"
  if_exists = "overwrite_terragrunt"
  contents  = <<-EOF_LOCAL
terraform {
  backend "local" {
    path = "${local.terraform_state_path}"
  }
}
EOF_LOCAL
}

generate "backend_cloud" {
  disable   = local.backend_mode == "local"
  path      = "backend.tf"
  if_exists = "overwrite_terragrunt"
  contents  = <<-EOF_CLOUD
terraform {
  cloud {
    organization = "${local.tfc_org}"
    workspaces {
      name = "${local.workspace_name}"
    }
  }
}
EOF_CLOUD
}

generate "provider" {
  path      = "provider.tf"
  if_exists = "overwrite_terragrunt"
  contents  = <<-EOF_PROVIDER
provider "aws" {
  region     = "${local.aws.region}"
  access_key = ${local.aws_access_key_expr}
  secret_key = ${local.aws_secret_key_expr}
  token      = ${local.aws_session_token_expr}
  profile    = ${local.aws_profile_expr}
}
EOF_PROVIDER
}

inputs = merge(local.tf_inputs, { aws_region = local.aws.region })
