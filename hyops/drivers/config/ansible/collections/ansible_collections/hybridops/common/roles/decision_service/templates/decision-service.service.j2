[Unit]
Description=HybridOps Edge Decision Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ decision_service_run_as_user }}
Group={{ decision_service_run_as_group }}
WorkingDirectory={{ decision_service_root }}
ExecStart=/usr/bin/env python3 {{ decision_service_bin_path }}
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths={{ decision_service_root }}

[Install]
WantedBy=multi-user.target
