#!/usr/bin/env python3
"""Manage the local decision-service demo signal."""

from __future__ import annotations

import argparse
import datetime
import json
import time
from pathlib import Path


SIGNAL_PATH = Path("{{ decision_service_demo_signal_path }}")


def _utc_now() -> str:
    return datetime.datetime.now(datetime.timezone.utc).isoformat()


def _read_payload() -> dict:
    try:
        return json.loads(SIGNAL_PATH.read_text(encoding="utf-8"))
    except Exception:
        return {}


def _write_payload(payload: dict) -> None:
    SIGNAL_PATH.parent.mkdir(parents=True, exist_ok=True)
    tmp = SIGNAL_PATH.with_suffix(".tmp")
    tmp.write_text(json.dumps(payload, sort_keys=True, indent=2), encoding="utf-8")
    tmp.replace(SIGNAL_PATH)


def _cmd_set(args: argparse.Namespace) -> int:
    pressure = max(0, int(args.pressure))
    payload = {
        "pressure": pressure,
        "active_until_epoch": (time.time() + int(args.ttl_s)) if int(args.ttl_s) > 0 else None,
        "note": str(args.note or "").strip(),
        "updated_at": _utc_now(),
    }
    _write_payload(payload)
    print(json.dumps(payload, sort_keys=True, indent=2))
    return 0


def _cmd_clear(_: argparse.Namespace) -> int:
    payload = {
        "pressure": 0,
        "active_until_epoch": None,
        "note": "",
        "updated_at": _utc_now(),
    }
    _write_payload(payload)
    print(json.dumps(payload, sort_keys=True, indent=2))
    return 0


def _cmd_show(_: argparse.Namespace) -> int:
    print(json.dumps(_read_payload(), sort_keys=True, indent=2))
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description="Manage the decision-service demo pressure signal.")
    sub = parser.add_subparsers(dest="command", required=True)

    set_parser = sub.add_parser("set", help="Set a synthetic burst-pressure signal.")
    set_parser.add_argument("--pressure", type=int, required=True, help="Pressure score to expose.")
    set_parser.add_argument("--ttl-s", type=int, default=180, help="How long the signal should remain active.")
    set_parser.add_argument("--note", default="", help="Optional note recorded with the signal.")
    set_parser.set_defaults(func=_cmd_set)

    clear_parser = sub.add_parser("clear", help="Clear the synthetic burst-pressure signal.")
    clear_parser.set_defaults(func=_cmd_clear)

    show_parser = sub.add_parser("show", help="Print the current synthetic burst-pressure signal.")
    show_parser.set_defaults(func=_cmd_show)

    args = parser.parse_args()
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
