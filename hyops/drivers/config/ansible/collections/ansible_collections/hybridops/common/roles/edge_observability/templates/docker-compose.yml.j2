version: "3.8"

services:
{% if edge_obs_enable_prometheus %}
  prometheus:
    image: {{ edge_obs_prometheus_image }}
    user: "{{ edge_obs_prometheus_uid }}:{{ edge_obs_prometheus_gid }}"
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --storage.tsdb.path=/prometheus
      - --storage.tsdb.retention.time={{ edge_obs_prometheus_retention_time }}
      - --web.listen-address=0.0.0.0:9090
    volumes:
      - "{{ edge_obs_config_dir }}/prometheus.yml:/etc/prometheus/prometheus.yml:ro"
      - "{{ edge_obs_data_dir }}/prometheus:/prometheus"
{% if edge_obs_enable_decision_service_scrape and edge_obs_decision_service_metrics_host == 'host.docker.internal' %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% endif %}
    ports:
      - "127.0.0.1:{{ edge_obs_prometheus_http_port }}:9090"
    restart: unless-stopped
    logging:
      driver: json-file
      options:
        max-size: "{{ edge_obs_docker_log_max_size }}"
        max-file: "{{ edge_obs_docker_log_max_file }}"
{% endif %}

{% if edge_obs_enable_blackbox_exporter %}
  blackbox-exporter:
    image: {{ edge_obs_blackbox_exporter_image }}
    command:
      - --config.file=/etc/blackbox/blackbox.yml
    volumes:
      - "{{ edge_obs_config_dir }}/blackbox.yml:/etc/blackbox/blackbox.yml:ro"
    ports:
      - "127.0.0.1:{{ edge_obs_blackbox_exporter_http_port }}:9115"
    restart: unless-stopped
    logging:
      driver: json-file
      options:
        max-size: "{{ edge_obs_docker_log_max_size }}"
        max-file: "{{ edge_obs_docker_log_max_file }}"
{% endif %}

{% if edge_obs_enable_thanos_sidecar %}
  thanos-sidecar:
    image: {{ edge_obs_thanos_image }}
    command:
      - sidecar
      - --grpc-address=0.0.0.0:10901
      - --http-address=0.0.0.0:10902
      - --prometheus.url=http://prometheus:9090
      - --tsdb.path=/prometheus
    volumes:
      - "{{ edge_obs_data_dir }}/prometheus:/prometheus:ro"
    restart: unless-stopped
    depends_on:
      - prometheus
    logging:
      driver: json-file
      options:
        max-size: "{{ edge_obs_docker_log_max_size }}"
        max-file: "{{ edge_obs_docker_log_max_file }}"
{% endif %}

{% if edge_obs_enable_receive %}
  thanos-receive:
    image: {{ edge_obs_thanos_image }}
    command:
      - receive
      - --grpc-address=0.0.0.0:10901
      - --http-address=0.0.0.0:10902
      - --remote-write.address=0.0.0.0:10907
      - --receive.hashrings-file=/etc/thanos/hashring.json
      - --objstore.config-file=/etc/thanos/objstore.yml
    volumes:
      - "{{ edge_obs_config_dir }}/hashring.json:/etc/thanos/hashring.json:ro"
      - "{{ edge_obs_config_dir }}/objstore.yml:/etc/thanos/objstore.yml:ro"
      - "{{ edge_obs_data_dir }}/receive:/var/thanos"
    ports:
      - "{{ edge_obs_receive_remote_write_port }}:10907"
    restart: unless-stopped
    logging:
      driver: json-file
      options:
        max-size: "{{ edge_obs_docker_log_max_size }}"
        max-file: "{{ edge_obs_docker_log_max_file }}"
{% endif %}

{% if edge_obs_enable_store_gateway %}
  thanos-store-gateway:
    image: {{ edge_obs_thanos_image }}
    command:
      - store
      - --grpc-address=0.0.0.0:10901
      - --http-address=0.0.0.0:10902
      - --data-dir=/var/thanos/store
      - --objstore.config-file=/etc/thanos/objstore.yml
    volumes:
      - "{{ edge_obs_config_dir }}/objstore.yml:/etc/thanos/objstore.yml:ro"
      - "{{ edge_obs_data_dir }}/store:/var/thanos/store"
    restart: unless-stopped
    logging:
      driver: json-file
      options:
        max-size: "{{ edge_obs_docker_log_max_size }}"
        max-file: "{{ edge_obs_docker_log_max_file }}"
{% endif %}

{% if edge_obs_enable_query %}
  thanos-query:
    image: {{ edge_obs_thanos_image }}
    command:
      - query
      - --grpc-address=0.0.0.0:10901
      - --http-address=0.0.0.0:10902
{% for store in edge_obs_query_upstreams_effective %}
      - --store={{ store }}
{% endfor %}
    ports:
      - "{{ edge_obs_query_http_port }}:10902"
    restart: unless-stopped
    logging:
      driver: json-file
      options:
        max-size: "{{ edge_obs_docker_log_max_size }}"
        max-file: "{{ edge_obs_docker_log_max_file }}"
{% endif %}

{% if edge_obs_enable_ruler %}
  thanos-ruler:
    image: {{ edge_obs_thanos_image }}
    command:
      - rule
      - --grpc-address=0.0.0.0:10901
      - --http-address=0.0.0.0:10902
      - --data-dir=/var/thanos/ruler
      - --rule-file=/etc/thanos/rules.yaml
      - --alertmanagers.url=http://alertmanager:9093
      - --query=thanos-query:10901
      - --objstore.config-file=/etc/thanos/objstore.yml
    volumes:
      - "{{ edge_obs_config_dir }}/objstore.yml:/etc/thanos/objstore.yml:ro"
      - "{{ edge_obs_config_dir }}/rules.yaml:/etc/thanos/rules.yaml:ro"
      - "{{ edge_obs_data_dir }}/ruler:/var/thanos/ruler"
    restart: unless-stopped
    logging:
      driver: json-file
      options:
        max-size: "{{ edge_obs_docker_log_max_size }}"
        max-file: "{{ edge_obs_docker_log_max_file }}"
{% endif %}

{% if edge_obs_enable_alertmanager %}
  alertmanager:
    image: {{ edge_obs_alertmanager_image }}
    command:
      - --config.file=/etc/alertmanager/alertmanager.yml
      - --storage.path=/alertmanager
    volumes:
      - "{{ edge_obs_config_dir }}/alertmanager.yml:/etc/alertmanager/alertmanager.yml:ro"
      - "{{ edge_obs_data_dir }}/alertmanager:/alertmanager"
    ports:
      - "{{ edge_obs_alertmanager_http_port }}:9093"
    restart: unless-stopped
    logging:
      driver: json-file
      options:
        max-size: "{{ edge_obs_docker_log_max_size }}"
        max-file: "{{ edge_obs_docker_log_max_file }}"
{% endif %}

{% if edge_obs_enable_grafana %}
  grafana:
    image: {{ edge_obs_grafana_image }}
    env_file:
      - "{{ edge_obs_env_path }}"
    volumes:
      - "{{ edge_obs_config_dir }}/grafana-datasources.yaml:/etc/grafana/provisioning/datasources/datasources.yaml:ro"
{% if edge_obs_enable_burst_dashboard %}
      - "{{ edge_obs_grafana_dashboard_provider_path }}:/etc/grafana/provisioning/dashboards/dashboards.yaml:ro"
      - "{{ edge_obs_grafana_dashboards_dir }}:/var/lib/grafana/dashboards:ro"
{% endif %}
      - "{{ edge_obs_data_dir }}/grafana:/var/lib/grafana"
    ports:
      - "{{ edge_obs_grafana_http_port }}:3000"
    restart: unless-stopped
    logging:
      driver: json-file
      options:
        max-size: "{{ edge_obs_docker_log_max_size }}"
        max-file: "{{ edge_obs_docker_log_max_file }}"
{% endif %}
