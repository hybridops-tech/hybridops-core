#!/usr/bin/env python3
"""
purpose: Local decision-consumer runtime.
maintainer: HybridOps
"""

from __future__ import annotations

import datetime
import json
import time
import uuid
from pathlib import Path

ROOT = Path("{{ decision_consumer_root }}")
CONFIG_PATH = ROOT / "config" / "config.json"
STATE_PATH = ROOT / "state" / "state.json"
LOG_PATH = ROOT / "logs" / "consumer.log"


def _utc_now() -> str:
    return datetime.datetime.now(datetime.timezone.utc).isoformat()


def _utc_now_token() -> str:
    return datetime.datetime.now(datetime.timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def _read_json(path: Path) -> dict:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


def _write_json(path: Path, payload: dict) -> None:
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(payload, sort_keys=True, indent=2), encoding="utf-8")
    tmp.replace(path)


def _append_log(payload: dict) -> None:
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with LOG_PATH.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(payload, sort_keys=True) + "\n")


def _sanitize_token(value: str) -> str:
    allowed = []
    for char in value.lower():
        if char.isalnum():
            allowed.append(char)
        elif char in {"-", "_"}:
            allowed.append(char)
    token = "".join(allowed).strip("-_")
    return token or "execution"


def _emit_execution_record(*, request: dict, approval: dict, config: dict, executions_dir: Path) -> dict:
    dispatch_id = str(request.get("dispatch_id") or "")
    execution_id = (
        f"execution-{_utc_now_token()}-"
        f"{_sanitize_token(dispatch_id)}-{uuid.uuid4().hex[:8]}"
    )
    payload = {
        "execution_id": execution_id,
        "timestamp_utc": _utc_now(),
        "status": "approved-ready",
        "execution_mode": str(config.get("execution_mode") or "approval-only"),
        "source_dispatch_id": dispatch_id,
        "decision_type": str(request.get("decision_type") or ""),
        "execution_plane": str(request.get("execution_plane") or ""),
        "target_kind": str(request.get("target_kind") or ""),
        "target_ref": str(request.get("target_ref") or ""),
        "target_env": str(request.get("target_env") or ""),
        "rationale": str(request.get("rationale") or ""),
        "checks": request.get("checks") if isinstance(request.get("checks"), list) else [],
        "approval": {
            "required": bool(request.get("requires_approval", config.get("require_approval", True))),
            "approval_file": str(approval.get("_source_file") or ""),
            "approved_by": str(approval.get("approved_by") or ""),
            "note": str(approval.get("note") or ""),
        },
    }
    executions_dir.mkdir(parents=True, exist_ok=True)
    record_path = executions_dir / f"{execution_id}.json"
    _write_json(record_path, payload)
    return {"execution_id": execution_id, "execution_file": str(record_path), "status": "approved-ready"}


def _process(config: dict, prior: dict) -> dict:
    requests_dir = Path(str(config.get("dispatch_requests_dir") or "").strip() or "/opt/hybridops/decision-dispatcher/state/requests")
    approvals_dir = Path(str(config.get("approval_dir") or "").strip() or (ROOT / "state" / "approvals"))
    executions_dir = Path(str(config.get("executions_dir") or "").strip() or (ROOT / "state" / "executions"))
    poll_seconds = int(config.get("poll_seconds", 15) or 15)
    if poll_seconds < 5:
        poll_seconds = 5
    execution_mode = str(config.get("execution_mode") or "approval-only").strip().lower() or "approval-only"
    require_approval = bool(config.get("require_approval", True))

    processed = prior.get("processed_request_ids")
    if not isinstance(processed, dict):
        processed = {}

    last_request_id = str(prior.get("last_request_id") or "")
    last_execution_id = str(prior.get("last_execution_id") or "")
    last_reason = "idle"
    pending_count = 0

    if requests_dir.exists():
        for path in sorted(requests_dir.glob("*.json")):
            request = _read_json(path)
            dispatch_id = str(request.get("dispatch_id") or path.stem).strip()
            if not dispatch_id or dispatch_id in processed:
                continue

            last_request_id = dispatch_id
            needs_approval = bool(request.get("requires_approval", require_approval))
            approval = {}
            if needs_approval:
                approval_path = approvals_dir / f"{dispatch_id}.approved.json"
                if not approval_path.exists():
                    pending_count += 1
                    last_reason = f"waiting-approval:{dispatch_id}"
                    continue
                approval = _read_json(approval_path)
                approval["_source_file"] = str(approval_path)

            result = _emit_execution_record(
                request=request,
                approval=approval,
                config=config,
                executions_dir=executions_dir,
            )
            processed[dispatch_id] = {
                "status": result.get("status"),
                "execution_id": result.get("execution_id"),
                "execution_file": result.get("execution_file"),
                "timestamp_utc": _utc_now(),
            }
            last_execution_id = str(result.get("execution_id") or "")
            last_reason = f"execution_record_emitted:{dispatch_id}"

    return {
        "timestamp_utc": _utc_now(),
        "status": "running",
        "execution_mode": execution_mode,
        "dispatch_requests_dir": str(requests_dir),
        "approvals_dir": str(approvals_dir),
        "executions_dir": str(executions_dir),
        "processed_count": len(processed),
        "pending_count": pending_count,
        "last_request_id": last_request_id,
        "last_execution_id": last_execution_id,
        "reason": last_reason,
        "processed_request_ids": processed,
        "poll_seconds": poll_seconds,
    }


def main() -> int:
    prior = _read_json(STATE_PATH)
    while True:
        config = _read_json(CONFIG_PATH)
        payload = _process(config=config, prior=prior)
        _write_json(STATE_PATH, payload)
        _append_log(payload)
        prior = payload
        poll_seconds = int(payload.get("poll_seconds", 15) or 15)
        if poll_seconds < 5:
            poll_seconds = 5
        time.sleep(poll_seconds)


if __name__ == "__main__":
    raise SystemExit(main())
