global:
  scrape_interval: {{ edge_obs_prometheus_scrape_interval | to_json }}
  evaluation_interval: {{ edge_obs_prometheus_scrape_interval | to_json }}
{% if (edge_obs_prometheus_external_labels_effective | default(edge_obs_prometheus_external_labels | default({})) | length) > 0 %}
  external_labels:
{%   for key, value in (edge_obs_prometheus_external_labels_effective | default(edge_obs_prometheus_external_labels | default({})) | dictsort) %}
    {{ key }}: {{ value | to_json }}
{%   endfor %}
{% endif %}

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - prometheus:9090

{% if edge_obs_enable_blackbox_exporter and (edge_obs_probe_targets | default([]) | length > 0) %}
  - job_name: edge_blackbox_http
    metrics_path: /probe
    params:
      module:
        - http_2xx
    static_configs:
{% for target in edge_obs_probe_targets %}
      - targets:
          - {{ target.url | to_json }}
        labels:
          probe_target: {{ target.name | to_json }}
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - source_labels: [probe_target]
        target_label: probe_target
      - target_label: __address__
        replacement: blackbox-exporter:9115
{% endif %}
