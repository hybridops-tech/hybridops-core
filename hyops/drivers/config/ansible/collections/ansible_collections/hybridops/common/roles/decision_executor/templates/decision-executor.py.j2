#!/usr/bin/env python3
"""
purpose: Local decision-executor runtime.
maintainer: HybridOps
"""

from __future__ import annotations

import datetime
import json
import time
import uuid
from pathlib import Path

ROOT = Path("{{ decision_executor_root }}")
CONFIG_PATH = ROOT / "config" / "config.json"
STATE_PATH = ROOT / "state" / "state.json"
LOG_PATH = ROOT / "logs" / "executor.log"


def _utc_now() -> str:
    return datetime.datetime.now(datetime.timezone.utc).isoformat()


def _utc_now_token() -> str:
    return datetime.datetime.now(datetime.timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def _read_json(path: Path) -> dict:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


def _write_json(path: Path, payload: dict) -> None:
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(payload, sort_keys=True, indent=2), encoding="utf-8")
    tmp.replace(path)


def _append_log(payload: dict) -> None:
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with LOG_PATH.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(payload, sort_keys=True) + "\n")


def _sanitize_token(value: str) -> str:
    allowed = []
    for char in value.lower():
        if char.isalnum():
            allowed.append(char)
        elif char in {"-", "_"}:
            allowed.append(char)
    token = "".join(allowed).strip("-_")
    return token or "attempt"


def _emit_attempt_record(*, execution: dict, config: dict, attempts_dir: Path) -> dict:
    execution_id = str(execution.get("execution_id") or "")
    attempt_id = (
        f"attempt-{_utc_now_token()}-"
        f"{_sanitize_token(execution_id)}-{uuid.uuid4().hex[:8]}"
    )
    payload = {
        "attempt_id": attempt_id,
        "timestamp_utc": _utc_now(),
        "status": "dry-run-ready",
        "execution_mode": str(config.get("execution_mode") or "dry-run"),
        "source_execution_id": execution_id,
        "source_execution_file": str(execution.get("_source_file") or ""),
        "source_dispatch_id": str(execution.get("source_dispatch_id") or ""),
        "decision_type": str(execution.get("decision_type") or ""),
        "execution_plane": str(execution.get("execution_plane") or ""),
        "target_kind": str(execution.get("target_kind") or ""),
        "target_ref": str(execution.get("target_ref") or ""),
        "target_env": str(execution.get("target_env") or ""),
        "rationale": str(execution.get("rationale") or ""),
        "checks": execution.get("checks") if isinstance(execution.get("checks"), list) else [],
        "approval": execution.get("approval") if isinstance(execution.get("approval"), dict) else {},
    }
    attempts_dir.mkdir(parents=True, exist_ok=True)
    record_path = attempts_dir / f"{attempt_id}.json"
    _write_json(record_path, payload)
    return {"attempt_id": attempt_id, "attempt_file": str(record_path), "status": "dry-run-ready"}


def _process(config: dict, prior: dict) -> dict:
    executions_dir = Path(
        str(config.get("execution_records_dir") or "").strip()
        or "/opt/hybridops/decision-consumer/state/executions"
    )
    attempts_dir = Path(str(config.get("attempts_dir") or "").strip() or (ROOT / "state" / "attempts"))
    poll_seconds = int(config.get("poll_seconds", 15) or 15)
    if poll_seconds < 5:
        poll_seconds = 5
    execution_mode = str(config.get("execution_mode") or "dry-run").strip().lower() or "dry-run"

    processed = prior.get("processed_execution_ids")
    if not isinstance(processed, dict):
        processed = {}

    last_execution_id = str(prior.get("last_execution_id") or "")
    last_attempt_id = str(prior.get("last_attempt_id") or "")
    last_reason = "idle"
    pending_count = 0

    if executions_dir.exists():
        for path in sorted(executions_dir.glob("*.json")):
            execution = _read_json(path)
            execution_id = str(execution.get("execution_id") or path.stem).strip()
            if not execution_id or execution_id in processed:
                continue
            execution["_source_file"] = str(path)
            last_execution_id = execution_id
            status = str(execution.get("status") or "").strip().lower()
            if status != "approved-ready":
                processed[execution_id] = {
                    "status": "ignored",
                    "reason": f"unsupported_status:{status or 'unknown'}",
                    "timestamp_utc": _utc_now(),
                }
                last_reason = f"ignored:unsupported_status:{status or 'unknown'}"
                continue

            result = _emit_attempt_record(execution=execution, config=config, attempts_dir=attempts_dir)
            processed[execution_id] = {
                "status": result.get("status"),
                "attempt_id": result.get("attempt_id"),
                "attempt_file": result.get("attempt_file"),
                "timestamp_utc": _utc_now(),
            }
            last_attempt_id = str(result.get("attempt_id") or "")
            last_reason = f"attempt_record_emitted:{execution_id}"

    return {
        "timestamp_utc": _utc_now(),
        "status": "running",
        "execution_mode": execution_mode,
        "execution_records_dir": str(executions_dir),
        "attempts_dir": str(attempts_dir),
        "processed_count": len(processed),
        "pending_count": pending_count,
        "last_execution_id": last_execution_id,
        "last_attempt_id": last_attempt_id,
        "reason": last_reason,
        "processed_execution_ids": processed,
        "poll_seconds": poll_seconds,
    }


def main() -> int:
    prior = _read_json(STATE_PATH)
    while True:
        config = _read_json(CONFIG_PATH)
        payload = _process(config=config, prior=prior)
        _write_json(STATE_PATH, payload)
        _append_log(payload)
        prior = payload
        poll_seconds = int(payload.get("poll_seconds", 15) or 15)
        if poll_seconds < 5:
            poll_seconds = 5
        time.sleep(poll_seconds)


if __name__ == "__main__":
    raise SystemExit(main())
