# purpose: strongSwan swanctl configuration for route-based IPsec
# generated by: hybridops.network.wan_edge
# maintainer: HybridOps.Studio

connections {
{% for t in wan_tunnels %}
  wan_{{ t.name }} {
    version = 2

    local_addrs  = {{ t.local_public_ip | default(wan_public_local_ip) }}
    remote_addrs = {{ t.peer_public_ip | default(wan_public_peer_ip) }}

    proposals   = {{ wan_ipsec.proposals }}
    dpd_delay   = {{ wan_ipsec.dpd_delay }}
    dpd_timeout = {{ wan_ipsec.dpd_timeout }}

    local {
      auth = psk
      id   = {{ t.local_public_ip | default(wan_public_local_ip) }}
    }

    remote {
      auth = psk
      id   = {{ t.peer_public_ip | default(wan_public_peer_ip) }}
    }

    children {
      wan_{{ t.name }} {
        esp_proposals = {{ wan_ipsec.esp_proposals }}

    {% if wan_bgp_transit | default(false) %}
        {# Hub/transit mode: include all routed prefixes #}
        local_ts  = {{ t.inside_local | ansible.utils.ipaddr('network/prefix') }},{{ wan_loopbacks | join(',') }},{{ wan_bgp.advertise | join(',') }},{{ wan_bgp.import_allow | join(',') }}
        remote_ts = {{ t.inside_peer }}/32,{{ wan_bgp.import_allow | join(',') }}
    {% else %}
        {# Spoke mode: only local prefixes #}
        local_ts  = {{ t.inside_local | ansible.utils.ipaddr('network/prefix') }},{{ wan_loopbacks | join(',') }},{{ wan_bgp.advertise | join(',') }}
        remote_ts = {{ t.inside_peer }}/32,{{ wan_bgp.import_allow | join(',') }}
    {% endif %}

        start_action = {{ t.start_action | default(wan_ipsec.start_action) | default('start') }}
        close_action = {{ t.close_action | default(wan_ipsec.close_action) | default('restart') }}
        dpd_action   = {{ t.dpd_action | default(wan_ipsec.dpd_action) | default('restart') }}

        mark_in  = {{ t.mark | default(t.key) }}
        mark_out = {{ t.mark | default(t.key) }}

        reqid = {{ t.key }}

        policies = yes
      }
    }
  }
{% endfor %}
}

secrets {
{% for t in wan_tunnels %}
  ike_psk_{{ t.name }} {
    id-1 = {{ t.local_public_ip | default(wan_public_local_ip) }}
    id-2 = {{ t.peer_public_ip | default(wan_public_peer_ip) }}
{% if wan_ipsec_psk_map[t.name] is defined %}
    secret = "{{ wan_ipsec_psk_map[t.name] }}"
{% else %}
    secret = "{{ t.psk | default(wan_ipsec.psk) }}"
{% endif %}
  }
{% endfor %}
}