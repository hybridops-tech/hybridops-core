# purpose: FRR BGP config for WAN edge/hub
# generated by: hybridops.network.wan_edge
# maintainer: HybridOps.Studio

frr defaults traditional
hostname {{ inventory_hostname }}
service integrated-vtysh-config
log syslog informational

{% set seq = namespace(v=10) -%}
ip prefix-list PL-OUT seq {{ seq.v }} permit {{ (wan_bgp.export_allow | first) if (wan_bgp.export_allow | length > 0) else '0.0.0.0/32' }}
{% for p in (wan_bgp.export_allow[1:] if (wan_bgp.export_allow | length > 1) else []) %}
{% set seq.v = seq.v + 10 -%}
ip prefix-list PL-OUT seq {{ seq.v }} permit {{ p }}
{% endfor %}
{% set seq.v = seq.v + 90 -%}
ip prefix-list PL-OUT seq {{ seq.v }} deny 0.0.0.0/0 le 32

{% set seq2 = namespace(v=10) -%}
ip prefix-list PL-IN seq {{ seq2.v }} permit {{ (wan_bgp.import_allow | first) if (wan_bgp.import_allow | length > 0) else '0.0.0.0/32' }}
{% for p in (wan_bgp.import_allow[1:] if (wan_bgp.import_allow | length > 1) else []) %}
{% set seq2.v = seq2.v + 10 -%}
ip prefix-list PL-IN seq {{ seq2.v }} permit {{ p }}
{% endfor %}
{% set seq2.v = seq2.v + 90 -%}
ip prefix-list PL-IN seq {{ seq2.v }} deny 0.0.0.0/0 le 32

router bgp {{ wan_bgp.local_as }}
 bgp router-id {{ wan_bgp.router_id }}
 no bgp ebgp-requires-policy

{% if wan_bgp.peer_groups is defined and wan_bgp.peer_groups | length > 0 %}
{# Hub mode: multiple peer-groups with different ASNs #}
{% for pg in wan_bgp.peer_groups %}
 neighbor {{ pg.name }} peer-group
 neighbor {{ pg.name }} remote-as {{ pg.remote_as }}
 neighbor {{ pg.name }} disable-connected-check
 neighbor {{ pg.name }} ebgp-multihop 2
{% for n in pg.neighbors %}
 neighbor {{ n }} peer-group {{ pg.name }}
{% endfor %}
{% endfor %}

 address-family ipv4 unicast
{% for net in wan_bgp.advertise %}
  network {{ net }}
{% endfor %}
{% for pg in wan_bgp.peer_groups %}
  neighbor {{ pg.name }} prefix-list PL-IN in
  neighbor {{ pg.name }} prefix-list PL-OUT out
  neighbor {{ pg.name }} soft-reconfiguration inbound
{% endfor %}
 exit-address-family
{% else %}
{# Spoke mode: single peer-group #}
 neighbor WAN peer-group
 neighbor WAN remote-as {{ wan_bgp.peer_as }}
 neighbor WAN disable-connected-check
 neighbor WAN ebgp-multihop 2

{% for n in wan_bgp.neighbors %}
 neighbor {{ n }} peer-group WAN
{% endfor %}

 address-family ipv4 unicast
{% for net in wan_bgp.advertise %}
  network {{ net }}
{% endfor %}
  neighbor WAN prefix-list PL-IN in
  neighbor WAN prefix-list PL-OUT out
  neighbor WAN soft-reconfiguration inbound
 exit-address-family
{% endif %}