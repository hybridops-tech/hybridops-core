exclude_paths:
  - .git/
  - .venv/
  - build/
  - dist/
  - hyops/drivers/config/ansible/collections/ansible_collections/hybridops/**/molecule/
  - hyops/drivers/config/ansible/collections/ansible_collections/hybridops/**/tests/
offline: true
warn_list:
  - fqcn[action-core]
  - meta-no-tags
  - name[casing]
  - run-once[task]
  - yaml[empty-lines]
  - yaml[line-length]
